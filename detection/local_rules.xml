<!--
  SOC Home Lab - Custom Wazuh detection rules
  Deployed to /var/ossec/etc/rules/local_rules.xml on the Wazuh manager.
  Rule 100100 introduced in C2-05; tuned in C2-06.
-->

<group name="windows,powershell,local,">

  <!--
    Detects a PowerShell download cradle via Script Block Logging (Event ID 4104).
    Chains to 91802, the built-in parent for PowerShell/Operational script-block
    events.

    Two field conditions on scriptBlockText are ANDed, so the rule fires only when
    a single script block contains BOTH a download method AND an execution call --
    the defining shape of a fileless download-and-execute. This is the C2-06 tuning:
    the first version matched either marker alone and alerted on benign
    Invoke-Expression use (e.g. Invoke-Expression $variable); requiring a download
    as well removes that false positive without losing the cradle.

    Sysmon Event 1 (process creation) was the first choice for this detection but
    proved unreliable in this environment; see docs/11-custom-detection-rule.md.
  -->
  <rule id="100100" level="12">
    <if_sid>91802</if_sid>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(DownloadString|DownloadFile|Net\.WebClient)</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(IEX|Invoke-Expression|\.Invoke\()</field>
    <description>PowerShell download cradle detected via Script Block Logging (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1105</id>
    </mitre>
    <group>attack,powershell_suspicious,</group>
  </rule>

</group>
